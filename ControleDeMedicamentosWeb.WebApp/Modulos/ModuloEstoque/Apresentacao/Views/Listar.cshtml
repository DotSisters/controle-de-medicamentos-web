@{
Layout = "_Layout";
ViewBag.Titulo = "📦 Estoque";
ViewBag.Info = "Cadastre, visualize e gerencie requisições de entrada e de saída do estoque.";
}

@model EstoqueViewModel;

<div class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Requisições de Entrada </h3>
            <p class="mb-0">Visualize e cadastre requisições de entrada.</p>
        </div>

        <a class="btn btn-primary rounded-pill px-4" asp-action="CadastrarEntrada">
            Cadastrar Entrada
        </a>
    </div>

    @if (TempData["MensagemErro"] is string mensagemErro)
    {
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
    }

    @if (Model.Entradas.Count == 0)
    {
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma requisição de entrada cadastrada.
    </div>
    }
    else
    {
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class=" table-primary">
                <tr>
                    <th>ID</th>
                    <th>Data de Criação</th>
                    <th>Funcionário</th>
                    <th>Medicamento</th>
                    <th>Quantidade</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entrada in Model.Entradas)
                {
                <tr class="bg-transparent">
                    <td>@entrada.Id.ToString().Substring(startIndex: 0, length: 8)</td>
                    <td>@entrada.DataCriacao.ToString("dd/MM/yyyy")</td>
                    <td>@entrada.NomeFuncionario</td>
                    <td>@entrada.NomeMedicamento</td>
                    <td>@entrada.Quantidade</td>
                </tr>
                }
            </tbody>
        </table>
    </div>
    }
</div>

<br>

<div class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Requisições de Saída</h3>
            <p class="mb-0">Visualize e cadastre requisições de saída.</p>
        </div>

        <a class="btn btn-primary rounded-pill px-4" asp-action="CadastrarSaida">
            Cadastrar Saída
        </a>
    </div>


    @if (Model.Saidas.Count == 0)
    {
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma requisição de saída cadastrada.
    </div>
    }
    else
    {
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class=" table-primary">
                <tr>
                    <th>ID</th>
                    <th>Data de Criação</th>
                    <th>Paciente</th>
                    <th>Medicação</th>
                    <th>Quantidade</th>
                </tr>
            </thead>
            <tbody>
                @foreach (ListarRequisicoesSaidaViewModel s in Model.Saidas)
                {
                @foreach (MedicamentoSaidaViewModel med in s.Medicamentos)
                {
                <tr>
                    <td>@s.Id.ToString().Substring(0,8)</td>
                    <td>@s.DataCriacao.ToString("dd/MM/yyyy")</td>
                    <td>@s.NomePaciente</td>
                    <td>@med.NomeMedicamento</td>
                    <td>@med.Quantidade</td>
                </tr>
                }
                }
            </tbody>
        </table>
    </div>
    }
</div>