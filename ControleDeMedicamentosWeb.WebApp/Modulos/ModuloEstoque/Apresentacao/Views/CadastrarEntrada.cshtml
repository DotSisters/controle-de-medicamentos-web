@{
  Layout = "_Layout";
  ViewBag.Titulo = "📋 Cadastrar Entrada";
  ViewBag.Info = "Registre as informações da nova requisição de entrada de medicamentos.";
}

@model CadastrarRequisicaoEntradaViewModel;

@if (Model.Funcionarios.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 620px;"
       role="alert">
    Cadastre um funcionário antes de cadastrar requisições de entrada.
  </div>
}

@if (Model.Medicamentos.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 620px;"
       role="alert">
    Cadastre um medicamento antes de cadastrar requisições de entrada.
  </div>
}

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
      asp-action="CadastrarEntrada" method="post">

  <div class="mb-3">
    <label asp-for="FuncionarioId" class="form-label fw-semibold text-primary text-uppercase small">Funcionario</label>
    <select asp-for="FuncionarioId" class="form-select">
      <option value="">Selecione uma funcionário</option>
      @foreach (OpcaoFuncionarioViewModel funcionario in Model.Funcionarios)
      {
        <option value="@funcionario.Id">@funcionario.Nome</option>
      }
    </select>
    <span asp-validation-for="FuncionarioId" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-3">
    <label asp-for="MedicamentoId" class="form-label fw-semibold text-primary text-uppercase small">Medicamento</label>
    <select asp-for="MedicamentoId" class="form-select">
      <option value="">Selecione um medicamento</option>
      @foreach (OpcaoMedicamentoViewModel medicamento in Model.Medicamentos)
      {
        <option value="@medicamento.Id">@medicamento.Nome</option>
      }
    </select>
    <span asp-validation-for="MedicamentoId" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-3">
    <label asp-for="Quantidade" class="form-label fw-semibold text-primary text-uppercase small">Quantidade</label>
    <input asp-for="Quantidade" type="number" min="0.01" step="0.01" class="form-control">
    <span asp-validation-for="Quantidade" class="text-danger small fw-semibold"></span>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
    @if (Model.Funcionarios.Count == 0 || Model.Medicamentos.Count == 0)
    {
      <button class="btn btn-primary rounded-pill px-4" type="submit" disabled>Confirmar</button>
    }
    else
    {
      <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    }
  </div>
</form>
