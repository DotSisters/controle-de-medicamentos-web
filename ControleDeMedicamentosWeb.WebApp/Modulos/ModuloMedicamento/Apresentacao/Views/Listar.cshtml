@{
Layout = "_Layout";
ViewBag.Titulo = "Medicamentos";
ViewBag.Info = "";
}

@model List<ListarMedicamentosViewModel>;

    <a class="btn btn-primary rounded-pill px-4 mb-4" asp-action="Cadastrar">Cadastrar Medicamento</a>

    @if (TempData["MensagemErro"] is string mensagemErro)
    {
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
    }

    @if (Model.Count == 0)
    {
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhum medicamento cadastrado.
    </div>
    }
    else
    {
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class=" table-primary">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Quantidade em Estoque</th>
                    <th>Descrição</th>
                    <th>Fornecedor</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (ListarMedicamentosViewModel m in Model)
                {
                <tr class="bg-transparent">
                    <td>@m.Id.ToString().Substring(startIndex: 0, length: 8)</td>
                    <td>@m.Nome</td>
                    <td>@m.QuantidadeEstoque</td>
                    <td>@m.Descricao</td>
                    <td>@m.FornecedorNome</td>
                    <td>
                        <div class="d-flex flex-sm-row flex-column gap-2">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                                asp-route-id="@m.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                                asp-route-id="@m.Id">Excluir</a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
    }