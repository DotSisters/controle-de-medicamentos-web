@{
Layout = "_Layout";
ViewBag.Titulo = "🗑️ Excluir Medicamento";
ViewBag.Info = "Confirme a exclusão deste medicamento.";
}

@model ExcluirMedicamentoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
    asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
        Deseja realmente excluir este medicamento?
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome do
            Medicamento</label>
        <input asp-for="Nome" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="QuantidadeEstoque" class="form-label fw-semibold text-primary text-uppercase small">Quantidade
            em Estoque</label>
        <input asp-for="QuantidadeEstoque" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">Descrição</label>
        <input asp-for="Descricao" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="FornecedorNome"
            class="form-label fw-semibold text-primary text-uppercase small">Fornecedor</label>
        <input asp-for="FornecedorNome" type="text" class="form-control" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>