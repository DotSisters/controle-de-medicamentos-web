@{
Layout = "_Layout";
ViewBag.Titulo = "Pacientes";
ViewBag.Info = "Cadastre, visualize e gerencie pacientes.";
}

@model List<ListarPacientesViewModel>

  <a class="btn btn-primary rounded-pill px-4 mb-4" asp-action="Cadastrar">Cadastrar Paciente</a>

  @if (TempData["MensagemErro"] is string mensagemErro)
  {
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
  }

  @if (Model.Count == 0)
  {
  <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
    Nenhum paciente cadastrado.
  </div>
  }
  else
  {
  <div class="table-responsive">
    <table class="table table-hover table-bordered align-middle bg-white">
      <thead class=" table-primary">
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Telefone</th>
          <th>Cartão SUS</th>
          <th>CPF</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        @foreach (ListarPacientesViewModel p in Model)
        {
        <tr class="bg-transparent">
          <td>@p.Id.ToString().Substring(0, 8)</td>
          <td>@p.Nome</td>
          <td>@p.Telefone</td>
          <td>@p.CartaoSUS</td>
          <td>@p.CPF</td>
          <td>
            <div class="d-flex flex-sm-row flex-column gap-2">
              <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                asp-route-id="@p.Id">Editar</a>
              <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                asp-route-id="@p.Id">Excluir</a>
            </div>
          </td>
        </tr>
        }
      </tbody>
    </table>
  </div>
  }