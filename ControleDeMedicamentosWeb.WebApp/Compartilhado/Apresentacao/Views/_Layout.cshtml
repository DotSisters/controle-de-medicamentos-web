<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    @* Importação do CSS do Bootstrap *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <title>@ViewBag.Titulo - Controle de Medicamentos</title>
</head>

<body style="
        background-image: linear-gradient(-20deg, #accbee 0%, #e7f0fd 100%);
        background-repeat: no-repeat;
        background-attachment: fixed;
        min-height: 100vh;
    ">
    @* Barra de Navegação *@
    <nav class="navbar navbar-expand-lg bg-white border-bottom"
        style="background-image: linear-gradient(120deg, #3279dd 0%, #0d6efd 100%);">
        <div class="container">
            <a class="navbar-brand fw-semibold text-white" asp-controller="Home" asp-action="Index">Medication
                Management</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Início</a>
                    <a class="nav-link text-white" asp-controller="Fornecedor" asp-action="Listar">Fornecedores</a>
                    <a class="nav-link text-white" asp-controller="Paciente" asp-action="Listar">Pacientes</a>
                    <a class="nav-link text-white" asp-controller="Medicamento" asp-action="Listar">Medicamentos</a>
                    <a class="nav-link text-white" asp-controller="Funcionario" asp-action="Listar">Funcionários</a>
                    <a class="nav-link text-white" asp-controller="Estoque" asp-action="Listar">Estoque</a>
                </div>
            </div>
        </div>
    </nav>

    @* Cabeçalho da Página *@
    <header class="container py-4">
        <h2>@ViewBag.Titulo</h2>
        <p>@ViewBag.Info</p>
    </header>

    @* Conteúdo da Página *@
    <main class="container pb-5">
        @RenderBody()
    </main>

    @* Importação do JavaScript do Bootstrap *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>